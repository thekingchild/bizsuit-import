{
  "name": "bizsuite-product-import-assistant",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "cf:preview": "npm run build && wrangler dev --no-bundle --cwd cloudflare --config wrangler.jsonc",
    "cf:deploy": "npm run build && wrangler deploy --no-bundle --cwd cloudflare --config wrangler.jsonc",
    "cf:deploy:dry-run": "npm run build && wrangler deploy --dry-run --no-bundle --cwd cloudflare --config wrangler.jsonc",
    "test": "npm run build && npm run catalogue:validate && node --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "catalogue:build": "node scripts/build-catalogue.mjs",
    "catalogue:validate": "node scripts/validate-catalogue.mjs",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
