{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "bizsuite-product-import-assistant",
  "main": "../dist/server/index.js",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": ["nodejs_compat"],
  "no_bundle": true,
  "rules": [
    {
      "type": "ESModule",
      "globs": ["**/*.js", "**/*.mjs"]
    }
  ],
  "assets": {
    "directory": "../dist/client",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
